      <!-- Close button -->
      <Button name="RaidMakerCEMainFrameCloseButton" inherits="UIPanelCloseButton">
        <Anchors>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-6" y="-6"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Button>
      <!-- Info button -->
      <Button name="RaidMakerCEInfoButton" inherits="UIPanelButtonTemplate" text="?">
        <Size>
          <AbsDimension x="24" y="24"/>
