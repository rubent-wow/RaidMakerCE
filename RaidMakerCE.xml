            </Anchor>
          </Anchors>
          <Color r="0.8" g="0.8" b="0"/>
        </FontString>
        <FontString name="RaidMakerCEHeaderStatus" inherits="GameFontNormalSmall" text="Status" justifyH="CENTER">
          <Size>
            <AbsDimension x="70" y="16"/>
          </Size>
          <Anchors>
            <Anchor point="LEFT" relativeTo="RaidMakerCEHeaderRole" relativePoint="RIGHT">
