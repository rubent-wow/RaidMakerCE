                <AbsDimension x="20" y="-70"/>
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Frames>
      <Button name="RaidMakerCECreateFrameCloseButton" inherits="UIPanelCloseButton">
        <Anchors>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-6" y="-6"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Button>
      <EditBox name="RaidMakerCECreateNameEditBox" autoFocus="false" enableMouse="true">
        <Size>
          <AbsDimension x="160" y="20"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="110" y="-38"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground" edgeFile="Interface\ChatFrame\ChatFrameBackground" tile="true">
          <BackgroundInsets>
            <AbsInset left="0" right="0" top="0" bottom="0"/>
          </BackgroundInsets>
          <TileSize>
            <AbsValue val="1"/>
          </TileSize>
          <EdgeSize>
            <AbsValue val="1"/>
          </EdgeSize>
        </Backdrop>
        <FontString inherits="ChatFontNormal"/>
        <Scripts>
          <OnEnterPressed>
            RaidMakerCEUI_SubmitCreateDialog();
          </OnEnterPressed>
          <OnEscapePressed>
            this:ClearFocus();
          </OnEscapePressed>
          <OnTabPressed>
            RaidMakerCECreateMaxEditBox:SetFocus();
          </OnTabPressed>
        </Scripts>
      </EditBox>
      <EditBox name="RaidMakerCECreateMaxEditBox" autoFocus="false" enableMouse="true" numeric="true">
        <Size>
          <AbsDimension x="50" y="20"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="110" y="-68"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground" edgeFile="Interface\ChatFrame\ChatFrameBackground" tile="true">
          <BackgroundInsets>
            <AbsInset left="0" right="0" top="0" bottom="0"/>
          </BackgroundInsets>
          <TileSize>
            <AbsValue val="1"/>
          </TileSize>
          <EdgeSize>
            <AbsValue val="1"/>
          </EdgeSize>
        </Backdrop>
        <FontString inherits="ChatFontNormal"/>
        <Scripts>
          <OnEnterPressed>
            RaidMakerCEUI_SubmitCreateDialog();
          </OnEnterPressed>
          <OnEscapePressed>
            this:ClearFocus();
          </OnEscapePressed>
          <OnTabPressed>
            RaidMakerCECreateNameEditBox:SetFocus();
          </OnTabPressed>
        </Scripts>
      </EditBox>
      <Button name="RaidMakerCECreateGoButton" inherits="UIPanelButtonTemplate" text="Create">
        <Size>
          <AbsDimension x="80" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="BOTTOMRIGHT" relativeTo="RaidMakerCECreateFrame">
            <Offset>
              <AbsDimension x="-100" y="14"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            local raidName = RaidMakerCECreateNameEditBox:GetText();
            local maxPlayers = RaidMakerCECreateMaxEditBox:GetText();
            if raidName and raidName ~= "" then
              RaidMakerCE_CreateRaid(raidName, maxPlayers);
              RaidMakerCECreateFrame:Hide();
            end
          </OnClick>
        </Scripts>
      </Button>
      <Button name="RaidMakerCECreateCancelButton" inherits="UIPanelButtonTemplate" text="Cancel">
        <Size>
          <AbsDimension x="80" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCECreateGoButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="8" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCECreateFrame:Hide();
          </OnClick>
        </Scripts>
      </Button>
    </Frames>
    <Scripts>
      <OnMouseDown>
        if arg1 == "LeftButton" then
          this:StartMoving();
        end
      </OnMouseDown>
      <OnMouseUp>
        this:StopMovingOrSizing();
      </OnMouseUp>
      <OnShow>
        RaidMakerCECreateNameEditBox:SetText("");
        RaidMakerCECreateMaxEditBox:SetText("");
        RaidMakerCECreateNameEditBox:SetFocus();
      </OnShow>
    </Scripts>
  </Frame>

