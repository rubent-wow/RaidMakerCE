        <Anchors>
          <Anchor point="RIGHT" relativeTo="RaidMakerCEMainFrameCloseButton" relativePoint="LEFT">
            <Offset>
              <AbsDimension x="2" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCEUI_ToggleInfoFrame();
