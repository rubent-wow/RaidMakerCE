      </Button>
      <!-- Settings button -->
      <Button name="RaidMakerCESettingsButton" inherits="UIPanelButtonTemplate" text="Config">
        <Size>
          <AbsDimension x="50" y="24"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT" relativeTo="RaidMakerCEMainFrame">
            <Offset>
              <AbsDimension x="14" y="-10"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCEUI_ToggleSettingsFrame();
          </OnClick>
        </Scripts>
      </Button>
      <!-- Scroll frame for roster -->
      <ScrollFrame name="RaidMakerCEScrollFrame" inherits="FauxScrollFrameTemplate">
        <Size>
          <AbsDimension x="384" y="320"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="14" y="-64"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnVerticalScroll>
            FauxScrollFrame_OnVerticalScroll(16, RaidMakerCEUI_UpdateRoster);
          </OnVerticalScroll>
        </Scripts>
      </ScrollFrame>
      <!-- Roster rows (20 visible) -->
      <Button name="RaidMakerCERow1" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCEScrollFrame"><Offset><AbsDimension x="0" y="0"/></Offset></Anchor></Anchors>
      </Button>
      <Button name="RaidMakerCERow2" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow1" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow3" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow2" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow4" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow3" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow5" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow4" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow6" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow5" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow7" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow6" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow8" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow7" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow9" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow8" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow10" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow9" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow11" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow10" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow12" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow11" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow13" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow12" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow14" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow13" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow15" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow14" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow16" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow15" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow17" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow16" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow18" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow17" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow19" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow18" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <Button name="RaidMakerCERow20" inherits="RaidMakerCERosterRowTemplate">
        <Anchors><Anchor point="TOPLEFT" relativeTo="RaidMakerCERow19" relativePoint="BOTTOMLEFT"/></Anchors>
      </Button>
      <!-- Buttons row -->
      <Button name="RaidMakerCEPasteButton" inherits="UIPanelButtonTemplate" text="Paste">
        <Size>
          <AbsDimension x="50" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="BOTTOMLEFT" relativeTo="RaidMakerCEMainFrame">
            <Offset>
              <AbsDimension x="14" y="14"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCEUI_ShowPasteDialog();
          </OnClick>
        </Scripts>
      </Button>
      <Button name="RaidMakerCECreateButton" inherits="UIPanelButtonTemplate" text="Create">
        <Size>
          <AbsDimension x="55" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCEPasteButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="4" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCEUI_ShowCreateDialog();
          </OnClick>
        </Scripts>
      </Button>
      <Button name="RaidMakerCEStartButton" inherits="UIPanelButtonTemplate" text="Start">
        <Size>
          <AbsDimension x="50" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCECreateButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="4" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCE_StartInviteMode();
          </OnClick>
        </Scripts>
      </Button>
      <Button name="RaidMakerCEStartQuietButton" inherits="UIPanelButtonTemplate" text="Quiet">
        <Size>
          <AbsDimension x="55" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCEStartButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="4" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCE_StartInviteMode(true);
          </OnClick>
        </Scripts>
      </Button>
      <Button name="RaidMakerCEOpenButton" inherits="UIPanelButtonTemplate" text="Open">
        <Size>
          <AbsDimension x="50" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCEStartQuietButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="4" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCE_OpenInviteMode();
          </OnClick>
        </Scripts>
      </Button>
      <Button name="RaidMakerCEStopButton" inherits="UIPanelButtonTemplate" text="Stop">
        <Size>
          <AbsDimension x="50" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCEOpenButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="4" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCE_StopInviteMode();
          </OnClick>
        </Scripts>
      </Button>
      <Button name="RaidMakerCEResetButton" inherits="UIPanelButtonTemplate" text="Reset">
        <Size>
          <AbsDimension x="55" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCEStopButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="4" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCE_Reset();
          </OnClick>
        </Scripts>
      </Button>
    </Frames>
    <Scripts>
      <OnMouseDown>
        if arg1 == "LeftButton" then
          this:StartMoving();
        end
      </OnMouseDown>
      <OnMouseUp>
        this:StopMovingOrSizing();
      </OnMouseUp>
      <OnShow>
        RaidMakerCEUI_UpdateRoster();
      </OnShow>
    </Scripts>
  </Frame>

  <!-- Paste dialog -->
  <Frame name="RaidMakerCEPasteFrame" toplevel="true" movable="true" enableMouse="true" hidden="true" parent="UIParent" frameStrata="DIALOG">
    <Size>
      <AbsDimension x="500" y="400"/>
    </Size>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
      <BackgroundInsets>
        <AbsInset left="11" right="12" top="12" bottom="11"/>
      </BackgroundInsets>
      <TileSize>
        <AbsValue val="32"/>
      </TileSize>
      <EdgeSize>
        <AbsValue val="32"/>
      </EdgeSize>
    </Backdrop>
    <Layers>
      <Layer level="ARTWORK">
        <FontString name="RaidMakerCEPasteFrameTitle" inherits="GameFontNormal" text="Paste raid-helper.xyz JSON">
          <Anchors>
            <Anchor point="TOP">
              <Offset>
                <AbsDimension x="0" y="-16"/>
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Frames>
      <Button name="RaidMakerCEPasteFrameCloseButton" inherits="UIPanelCloseButton">
        <Anchors>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-6" y="-6"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Button>
      <!-- Scrollable edit box -->
      <ScrollFrame name="RaidMakerCEPasteScrollFrame">
        <Size>
          <AbsDimension x="460" y="300"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="18" y="-36"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Frames>
          <EditBox name="RaidMakerCEPasteEditBox" multiLine="true" autoFocus="true" enableMouse="true">
            <Size>
              <AbsDimension x="460" y="300"/>
            </Size>
            <FontString inherits="ChatFontNormal"/>
            <Scripts>
              <OnTextChanged>
                local parent = this:GetParent();
                parent:UpdateScrollChildRect();
              </OnTextChanged>
              <OnEscapePressed>
                this:ClearFocus();
                RaidMakerCEPasteFrame:Hide();
              </OnEscapePressed>
            </Scripts>
          </EditBox>
        </Frames>
        <Scripts>
          <OnLoad>
            this:SetScrollChild(RaidMakerCEPasteEditBox);
          </OnLoad>
        </Scripts>
      </ScrollFrame>
      <!-- Load button -->
      <Button name="RaidMakerCEPasteLoadButton" inherits="UIPanelButtonTemplate" text="Load">
        <Size>
          <AbsDimension x="80" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="BOTTOMRIGHT" relativeTo="RaidMakerCEPasteFrame">
            <Offset>
              <AbsDimension x="-100" y="14"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            local text = RaidMakerCEPasteEditBox:GetText();
            if text and text ~= "" then
              local success = RaidMakerCE_LoadJSON(text);
              if success then
                RaidMakerCEPasteFrame:Hide();
                RaidMakerCEMainFrame:Show();
              end
            end
          </OnClick>
        </Scripts>
      </Button>
      <!-- Cancel button -->
      <Button name="RaidMakerCEPasteCancelButton" inherits="UIPanelButtonTemplate" text="Cancel">
        <Size>
          <AbsDimension x="80" y="22"/>
        </Size>
        <Anchors>
          <Anchor point="LEFT" relativeTo="RaidMakerCEPasteLoadButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="8" y="0"/>
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            RaidMakerCEPasteFrame:Hide();
          </OnClick>
        </Scripts>
      </Button>
    </Frames>
    <Scripts>
      <OnMouseDown>
        if arg1 == "LeftButton" then
          this:StartMoving();
        end
      </OnMouseDown>
      <OnMouseUp>
        this:StopMovingOrSizing();
      </OnMouseUp>
      <OnShow>
        RaidMakerCEPasteEditBox:SetText("");
        RaidMakerCEPasteEditBox:SetMaxLetters(50000);
        RaidMakerCEPasteEditBox:SetFocus();
      </OnShow>
    </Scripts>
  </Frame>

  <!-- Create raid dialog -->
  <Frame name="RaidMakerCECreateFrame" toplevel="true" movable="true" enableMouse="true" hidden="true" parent="UIParent" frameStrata="DIALOG">
    <Size>
      <AbsDimension x="300" y="160"/>
    </Size>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
      <BackgroundInsets>
        <AbsInset left="11" right="12" top="12" bottom="11"/>
      </BackgroundInsets>
      <TileSize>
        <AbsValue val="32"/>
      </TileSize>
      <EdgeSize>
        <AbsValue val="32"/>
      </EdgeSize>
    </Backdrop>
    <Layers>
      <Layer level="ARTWORK">
