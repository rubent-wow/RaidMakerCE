                <AbsDimension x="4" y="0"/>
              </Offset>
            </Anchor>
          </Anchors>
          <Color r="0.8" g="0.8" b="0"/>
        </FontString>
        <FontString name="RaidMakerCEHeaderRole" inherits="GameFontNormalSmall" text="Role">
          <Size>
            <AbsDimension x="60" y="16"/>
          </Size>
          <Anchors>
            <Anchor point="LEFT" relativeTo="RaidMakerCEHeaderClass" relativePoint="RIGHT">
